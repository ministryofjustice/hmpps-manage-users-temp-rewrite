{% extends "../../partials/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% set title = "Delete Email Domain" %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Home", href: homeUrl },
      { text: "Manage user accounts", href: '/' },
      { text: "Manage Email Domains", href: listUrl },
      { text: title }
    ]
  }) }}
{% endblock %}
{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ title }}</h1>
      <form action="{{ deleteUrl }}" method="POST">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>

        {{ govukWarningText({
          text: "This action cannot be undone",
          iconFallbackText: "Warning"
        }) }}

        <p class="govuk-body govuk-!-margin-bottom-5">Do you want to delete the email domain: <span
            class="govuk-!-font-weight-bold" data-qa="domain-name">{{ domain }}</span>?</p>

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Delete Email Domain",
            preventDoubleClick: true,
            type: "submit",
            classes: "govuk-button--warning",
            attributes: { "data-qa": "delete-domain-button" }
          }) }}

          {{ govukButton({
            text: "Cancel",
            element: 'a',
            href: listUrl,
            classes: "govuk-button--secondary",
            attributes: { "id": "cancel-button" }
          }) }}
        </div>
      </form>
    </div>
  </div>
{% endblock %}
