{% extends "../../partials/layout.njk" %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% set title = "Create Email Domain" %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Home", href: homeUrl },
      { text: "Manage user accounts", href: '/' },
      { text: "Manage Email Domains", href: listUrl },
      { text: title }
    ]
  }) }}
{% endblock %}

{% block content %}
  {% if errors.length > 0 %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: errors,
      attributes: { 'data-qa': 'error-summary'}
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ title }}</h1>
      <form action="{{ createUrl }}" method="POST">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>

        {{ govukInput({label: {
          text: "Domain Name", classes: "govuk-label--s"
        },
          classes: "govuk-input--width-30",
          value: name,
          id: "name",
          name: "name",
          errorMessage: errors | findError('name')
        }) }}

        {{ govukInput({label: {
          text: "Domain Description", classes: "govuk-label--s"
        },
          classes: "govuk-input--width-30",
          value: description,
          id: "description",
          name: "description",
          errorMessage: errors | findError('description')
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Add Email Domain",
            preventDoubleClick: true,
            type: "submit",
            attributes: { "data-qa": "create-button" }
          }) }}

          {{ govukButton({
            text: "Cancel",
            element: 'a',
            href: listUrl,
            classes: "govuk-button--secondary",
            attributes: { "id": "cancel-button" }
          }) }}
        </div>
      </form>
    </div>
  </div>
{% endblock %}
