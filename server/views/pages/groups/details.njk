{% extends "../../partials/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% macro groupActions(changeNameUrl, deleteUrl, groupCode, header=true) %}
  <div{% if header %} class="govuk-!-padding-top-2" {% endif %}>
    <a class="govuk-link" data-qa="change-name-{{ groupCode }}" href="{{ changeNameUrl }}">Change<span
        class="govuk-visually-hidden"> {{ groupCode }} group name</span></a>
    <a class="govuk-link govuk-!-padding-left-2" data-qa="delete-{{ groupCode }}" href="{{ deleteUrl }}">Delete<span
        class="govuk-visually-hidden"> {{ groupCode }}</span></a>
  </div>
{% endmacro %}

{% set title = groupDetails.groupName %}

 {% block beforeContent %}
   {{ govukBreadcrumbs({
     items: [
       { text: "Home", href: homeUrl },
       { text: "Manage user accounts", href: '/' },
       { text: 'Manage groups', href: maintainUrl },
       { text: title }
     ]
   }) }}
 {% endblock %}


{% block content %}
  {% if errors.length > 0 %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: errors,
      attributes: { 'data-qa': 'error-summary'}
    }) }}
  {% endif %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% set heading = '<h1 class="govuk-heading-l">' +  title  + '</h1>' %}
      {% set changeGroupLink %}
        {{ maintainUrl + "/" + groupDetails.groupCode + "/change-group-name" }}
      {% endset %}
      {% set deleteGroupLink %}
        {{ maintainUrl + "/" + groupDetails.groupCode + "/delete" }}
      {% endset %}
      {% set groupActionsHtml %}
        {{ groupActions(changeGroupLink, deleteGroupLink, groupDetails.groupCode) if hasMaintainAuthUsers else "" }}
      {% endset %}

      {{ govukTable({
        rows: [
          [
            { html: heading },
            { html: groupActionsHtml, format: "numeric" }
          ]
        ],
        attributes: { "data-qa": "header" }
      }) }}

      {{ govukTable({
        caption: "Group details",
        rows: [
          [
            { text: "Group code", classes: "govuk-!-width-one-third" },
            { text: groupDetails.groupCode },
            { text: "" }
          ]
        ],
        attributes: { "data-qa": "details" }
      }) }}

      {% set rows = [] %}
      {% for role in groupDetails.assignableRoles %}
        {% if role.automatic %}
          {% set auto = '<strong class="govuk-tag govuk-tag--turquoise"> Automatic </strong>' %}
        {% else %}
          {% set auto = '<strong class="govuk-tag govuk-tag--blue"> Manual </strong>' %}
        {% endif %}

        {% set rows = (rows.push([
          { text: role.roleName, classes: "govuk-!-width-one-third" },
          { html: auto }
        ]), rows) %}
      {% endfor %}

      {{ govukTable({
        caption: "Assignable roles",
        rows: rows,
        attributes: { "data-qa": "assignable-roles" }
      }) }}

      {% if groupDetails.children.length > 0 %}
        {% set rows = [] %}
        {% for cg in groupDetails.children %}
          {% set changeChildGroupLink %}
            {{ maintainUrl + "/" + groupDetails.groupCode + "/change-child-group-name/" + cg.groupCode }}
          {% endset %}
          {% set deleteChildGroupLink %}
            {{ maintainUrl + "/" + groupDetails.groupCode + "/delete-child-group/" + cg.groupCode }}
          {% endset %}
          {% set childGroupActionsHtml %}
            {{ groupActions(changeChildGroupLink, deleteChildGroupLink, cg.groupCode, false) if hasMaintainAuthUsers else "" }}
          {% endset %}
          {% set rows = (rows.push([
            { text: cg.groupName, classes: "govuk-!-width-one-third" },
            { text: cg.groupCode },
            { html: childGroupActionsHtml, format: "numeric" }
          ]), rows) %}
        {% endfor %}
        {{ govukTable({
          caption: "Child groups",
          rows: rows,
          attributes: { "data-qa": "child-groups" }
        }) }}
      {% endif %}

      {% if hasMaintainAuthUsers %}
        {{ govukButton({
          text: "Create child group",
          element: 'a',
          href: maintainUrl + '/' + groupDetails.groupCode + '/create-child-group',
          classes: "govuk-button",
          attributes: { "data-qa": "create-child-group-button" }
        }) }}
      {% endif %}

      {% set searchUrl = '/search-external-users?groupCode='+ groupDetails.groupCode %}
      <p class="govuk-body">
        <a href="{{ searchUrl }}" class="govuk-link" data-qa="search-link">Search for members of this group</a>
      </p>

    </div>
  </div>
{% endblock %}
