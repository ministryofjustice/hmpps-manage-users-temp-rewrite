{% extends "../../partials/layout.njk" %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{%- from "govuk/components/table/macro.njk" import govukTable -%}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% set title = "Manage groups" %}

 {% block beforeContent %}
   {{ govukBreadcrumbs({
     items: [
       { text: "Home", href: homeUrl },
       { text: "Manage user accounts", href: '/' },
       { text: title }
     ]
   }) }}
 {% endblock %}

{% block content %}
  {% if errors.length > 0 %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: errors,
      attributes: { 'data-qa': 'error-summary'}
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ title }}</h1>
      {% if groupValues.length == 0 %}
        <p class="govuk-body" data-qa="no-groups">
          You are not a member of any groups.
        </p>
      {% else %}
        {% if groupValues.length > 10 %}
          <form method="POST" action="{{ maintainUrl }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>

            <div class="govuk-list">
              <input type='hidden' name='status' value='ALL'/>
              {{ govukSelect({
                classes: 'autocomplete-select',
                label: {
                  text: "Select a group"
                },
                idPrefix: 'groupCode',
                name: 'groupCode',
                id: 'groupCode',
                items: groupValues | addBlankOptions('Select a group'),
                errorMessage: errors | findError('groupCode')
              }) }}
            </div>
            {{ govukButton({
              text: "Manage",
              type: "submit",
              attributes: { "data-qa": "manage-button" }
            }) }}
          </form>
        {% else %}
          {% set rows = [] %}
          {% for g in groupValues %}
            {% set groupLink %}
              <a href="{{ maintainUrl }}/{{ g.value }}" class="govuk-link"
                 data-qa="edit-link-{{ g.value }}">{{ g.text }}</a>
            {% endset %}
            {% set rows = (rows.push([
              { html: groupLink }
            ]), rows) %}
          {% endfor %}
          {{ govukTable({
            rows: rows,
            attributes: { "data-qa": "groups" }
          }) }}
        {% endif %}
      {% endif %}
    </div>
  </div>
{% endblock %}
