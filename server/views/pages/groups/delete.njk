{% extends "../../partials/layout.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "govuk/components/input/macro.njk" import govukInput %}

{% set title = "Delete " + groupText %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Home", href: homeUrl },
      { text: "Manage user accounts", href: '/' },
      { text: 'Manage groups', href: maintainUrl },
      { text: breadcrumbsGroupName, href: groupUrl },
      { text: title }
    ]
  }) }}
{% endblock %}
{% block content %}
  {% if errors.length > 0 %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: errors,
      attributes: { 'data-qa': 'error-summary'}
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l">{{ groupDetails.groupName }}</span>
      <h1 class="govuk-heading-l">{{ title }}</h1>
      <form method="POST">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>

        {{ govukWarningText({
          text: "This action cannot be undone",
          iconFallbackText: "Warning"
        }) }}
        {{ govukWarningText({
          text: "All the user membership of this " + groupText + " will be removed",
          iconFallbackText: "Warning"
        }) }}

        {% set hintHtml %}
          Enter <span class="govuk-!-font-weight-bold" data-qa="group-code">"{{ groupDetails.groupCode }}"</span> to confirm
        {% endset %}

        {{ govukInput({label: {
          text: "Are you sure you want to delete this " + groupText + "?", classes: "govuk-label--s"
        },
          hint: {
            html: hintHtml
          },
          classes: "govuk-input--width-30",
          value: confirmedGroup,
          id: "confirmedGroup",
          name: "confirmedGroup",
          errorMessage: errors | findError('confirmedGroup')
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Delete " + groupText,
            preventDoubleClick: true,
            type: "submit",
            classes: "govuk-button--warning",
            attributes: { "data-qa": "delete-group-button" }
          }) }}

          {{ govukButton({
            text: "Cancel",
            element: 'a',
            href: groupUrl,
            classes: "govuk-button--secondary",
            attributes: { "id": "cancel-button" }
          }) }}
        </div>
      </form>
    </div>
  </div>
{% endblock %}
