{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}


  {% set inputName = params.name + '-search' %}
  {% set counterTotalSelectedId = params.name + '-total-search-counter' %}

<div class="multi-select-filter">
  <div>
    {{ govukInput({
      label: { text: params.title, classes: "govuk-label--s" },
      classes: "govuk-input--width-20 search-input",
      value: '',
      id: inputName,
      describedBy: counterTotalSelectedId,
      hint: {
        text: params.hint
      }
    }) }}
  </div>
  <div class="selected-counter govuk-!-font-size-16" id={{ counterTotalSelectedId }}></div>
  <div role="group" class="options-container">
    {{ govukCheckboxes({
      idPrefix: params.name,
      name: params.name,
      items: params.items,
      classes: "govuk-checkboxes--small"
    }) }}
  </div>
</div>
